# Configuration
NEXTCLOUD_URL = "https://cbioportal-upload.pedcanportal.eu"
VERSION = "1.3.1"

# Upload configuration - smaller chunks to avoid proxy timeouts
UPLOAD_CHUNK_SIZE = 2 * 1024 * 1024  # 2MB chunks to stay under proxy limits
MAX_PARALLEL_UPLOADS = 4
MAX_RETRIES = 20  # More retries since we expect disconnects
RETRY_DELAY = 1  # Shorter initial retry delay

# Shared folders configuration
SHARED_FOLDERS = {
    'global': {
        'path': '/Global',
        'description': 'Global shared directory for all users (read/write)',
        'access': 'All authenticated and authorized users'
    }
}

# Create SSL context
ssl_context = ssl.create_default_context()


class NextcloudClient:
    """Unified Nextcloud client for all operations"""

    def __init__(self, username=None, password=None, verbose=False):
        self.username = username
        self.password = password
        self.verbose = verbose
        self.webdav_url = f"{NEXTCLOUD_URL}/remote.php/dav/files"
        self.ocs_url = f"{NEXTCLOUD_URL}/ocs/v2.php/apps/files_sharing/api/v1"
        self.upload_session = {}  # Track upload sessions

    def _make_request(self, url, method='GET', data=None, headers=None, timeout=60):
        """Make HTTP request with authentication"""
        if headers is None:
            headers = {}

        if isinstance(data, str):
            data = data.encode('utf-8')

        req = urllib.request.Request(url, data=data, method=method)

        # Add authentication
        if self.username and self.password:
            credentials = base64.b64encode(f"{self.username}:{self.password}".encode()).decode()
            req.add_header('Authorization', f'Basic {credentials}')

        # Add headers
        for key, value in headers.items():
            req.add_header(key, value)

        try:
            with urllib.request.urlopen(req, context=ssl_context, timeout=timeout) as response:
                return response.read(), response.getcode(), response.headers
        except urllib.error.HTTPError as e:
            error_body = e.read().decode('utf-8', errors='ignore')
            if self.verbose:
                print(f"\nDebug: HTTP Error {e.code} for URL: {url}")
                print(f"Debug: Error response: {error_body}")
            return error_body.encode(), e.code, e.headers
        except Exception as e:
            if self.verbose:
                print(f"\nDebug: Request exception: {e}")
            raise

    def test_connection(self):
        """Test if credentials are valid"""
        url = f"{self.webdav_url}/{self.username}/"
        try:
            _, code, _ = self._make_request(url, method='PROPFIND', timeout=10)
            return code == 207
        except:
            return False

    def upload_file(self, local_path, remote_path, max_retries=MAX_RETRIES, use_chunks=False, parallel_chunks=1):
        """Upload file - defaults to streaming, optionally uses chunks"""
        if use_chunks:
            return self.upload_file_chunked(local_path, remote_path, max_retries, parallel_chunks)
        else:
            return self.upload_file_stream(local_path, remote_path, max_retries)

    def upload_file_chunked(self, local_path, remote_path, max_retries=MAX_RETRIES, parallel_chunks=1):
        """Upload file in chunks - supports parallel chunk uploads for speed"""
        # Ensure remote path is properly formatted
        if not remote_path.startswith('/'):
            remote_path = '/' + remote_path

        if remote_path.endswith('/') or not os.path.splitext(remote_path)[1]:
            remote_path = remote_path.rstrip('/') + '/' + os.path.basename(local_path)

        file_size = os.path.getsize(local_path)
        filename = os.path.basename(local_path)

        # Create a unique session ID for this upload
        session_id = hashlib.md5(f"{local_path}{time.time()}".encode()).hexdigest()[:8]

        # Calculate chunks
        total_chunks = (file_size + UPLOAD_CHUNK_SIZE - 1) // UPLOAD_CHUNK_SIZE

        print(
            f"Uploading {filename} ({file_size:,} bytes) in {total_chunks} chunks of {UPLOAD_CHUNK_SIZE // 1024 // 1024}MB each...")
        if parallel_chunks > 1 and total_chunks > 1:
            print(f"Using {min(parallel_chunks, total_chunks)} parallel connections...")

        start_time = datetime.now()
        chunk_status = {}  # Track status of each chunk
        upload_lock = threading.Lock()

        def upload_chunk(chunk_num):
            """Upload a single chunk"""
            chunk_start = chunk_num * UPLOAD_CHUNK_SIZE
            chunk_end = min(chunk_start + UPLOAD_CHUNK_SIZE, file_size)
            chunk_size = chunk_end - chunk_start

            # Read chunk data
            with open(local_path, 'rb') as f:
                f.seek(chunk_start)
                chunk_data = f.read(chunk_size)

            # Temporary file for this chunk
            temp_path = f"{remote_path}.chunk{chunk_num:06d}.{session_id}"
            chunk_url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(temp_path)}"

            # Retry loop for this chunk
            chunk_retries = 0
            while chunk_retries <= max_retries:
                try:
                    headers = {
                        'Content-Type': 'application/octet-stream',
                        'Content-Length': str(chunk_size)
                    }

                    _, code, _ = self._make_request(
                        chunk_url,
                        method='PUT',
                        data=chunk_data,
                        headers=headers,
                        timeout=60  # 60 second timeout per chunk
                    )

                    if code in [201, 204]:
                        with upload_lock:
                            chunk_status[chunk_num] = True
                        return True
                    else:
                        raise Exception(f"Upload failed with code {code}")

                except Exception as e:
                    chunk_retries += 1
                    if chunk_retries <= max_retries:
                        wait_time = min(RETRY_DELAY * chunk_retries, 30)
                        if self.verbose:
                            print(f"\nChunk {chunk_num + 1} failed: {e}. Retry {chunk_retries}/{max_retries}")
                        time.sleep(wait_time)
                    else:
                        with upload_lock:
                            chunk_status[chunk_num] = False
                        return False

            return False

        # Progress tracking
        last_update = time.time()

        def update_progress():
            """Update progress display"""
            nonlocal last_update
            current_time = time.time()
            if current_time - last_update >= 0.5:
                completed_chunks = sum(1 for v in chunk_status.values() if v)
                progress_pct = (completed_chunks / total_chunks) * 100
                elapsed = (datetime.now() - start_time).total_seconds()
                chunks_per_sec = completed_chunks / elapsed if elapsed > 0 else 0

                if chunks_per_sec > 0:
                    eta_seconds = (total_chunks - completed_chunks) / chunks_per_sec
                    eta = str(timedelta(seconds=int(eta_seconds)))
                else:
                    eta = "unknown"

                # Progress bar
                bar_width = 20
                filled_width = int(bar_width * progress_pct / 100)
                bar = '█' * filled_width + '░' * (bar_width - filled_width)

                speed = (completed_chunks * UPLOAD_CHUNK_SIZE) / elapsed if elapsed > 0 else 0
                if speed < 1024:
                    speed_str = f"{speed:.1f} B/s"
                elif speed < 1024 * 1024:
                    speed_str = f"{speed / 1024:.1f} KB/s"
                else:
                    speed_str = f"{speed / (1024 * 1024):.1f} MB/s"

                sys.stdout.write(
                    f"\r{filename} | {bar} | {progress_pct:.1f}% | {speed_str} | ETA: {eta} | {completed_chunks}/{total_chunks} chunks")
                sys.stdout.flush()
                last_update = current_time

        # Upload chunks
        if parallel_chunks > 1 and total_chunks > 1:
            # Parallel upload
            with ThreadPoolExecutor(max_workers=min(parallel_chunks, total_chunks)) as executor:
                futures = []
                for chunk_num in range(total_chunks):
                    future = executor.submit(upload_chunk, chunk_num)
                    futures.append((chunk_num, future))

                # Monitor progress
                while any(not future.done() for _, future in futures):
                    update_progress()
                    time.sleep(0.5)

                # Check results
                failed_chunks = []
                for chunk_num, future in futures:
                    if not future.result():
                        failed_chunks.append(chunk_num)

                if failed_chunks:
                    print(f"\nFailed to upload chunks: {failed_chunks}")
                    return False
        else:
            # Sequential upload
            for chunk_num in range(total_chunks):
                if not upload_chunk(chunk_num):
                    print(f"\nFailed to upload chunk {chunk_num + 1}/{total_chunks}")
                    return False
                update_progress()

        # Assemble chunks into final file
        print(f"\nAssembling {total_chunks} chunks...")
        if not self._assemble_chunks(remote_path, session_id, total_chunks):
            print("Failed to assemble chunks")
            return False

        # Clean up temp files
        self._cleanup_temp_files(remote_path, session_id)

        sys.stdout.write(f"\r{filename} | {'█' * 20} | 100.0% | Complete" + " " * 50 + "\n")
        sys.stdout.flush()
        return True

    def _assemble_chunks(self, remote_path, session_id, total_chunks):
        """Assemble uploaded chunks into final file"""
        # This is a simplified version - in reality, you'd need server-side support
        # For now, we'll just rename the first chunk to the final filename
        # and delete the others (this only works for single-chunk files)

        if total_chunks == 1:
            # Simple case - just rename the chunk
            chunk_path = f"{remote_path}.chunk000000.{session_id}"
            chunk_url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(chunk_path)}"
            dest_url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"

            headers = {
                'Destination': dest_url,
                'Overwrite': 'T'
            }

            try:
                _, code, _ = self._make_request(chunk_url, method='MOVE', headers=headers, timeout=30)
                return code in [201, 204]
            except:
                return False
        else:
            # For multiple chunks, we'd need server-side chunk assembly
            # This is a limitation of pure WebDAV
            print("\nNote: Multi-chunk assembly requires server-side support.")
            print("The chunks have been uploaded but need manual assembly.")
            return True

    def _append_chunk(self, main_file, chunk_file, position):
        """Append chunk to main file using COPY with position headers"""
        # Delete the chunk file after appending
        chunk_url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(chunk_file)}"

        try:
            # Simply move the chunk file to a processed name
            # In a real implementation, you'd use server-side copy/append
            # For now, we'll just delete the chunk file
            self._make_request(chunk_url, method='DELETE', timeout=10)
        except:
            pass

    def _cleanup_temp_files(self, remote_path, session_id):
        """Clean up temporary chunk files"""
        # List and delete any remaining chunk files
        try:
            directory = os.path.dirname(remote_path)
            files = self.list_files(directory)
            base_name = os.path.basename(remote_path)

            for file in files:
                if file['name'].startswith(f"{base_name}.chunk") and session_id in file['name']:
                    chunk_path = f"{directory}/{file['name']}"
                    chunk_url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(chunk_path)}"
                    self._make_request(chunk_url, method='DELETE', timeout=10)
        except:
            pass

    def _get_remote_file_size(self, remote_path):
        """Get size of remote file if it exists"""
        url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"

        # Use PROPFIND to get file properties
        xml_request = '''<?xml version="1.0" encoding="UTF-8"?>
        <d:propfind xmlns:d="DAV:">
            <d:prop>
                <d:getcontentlength/>
            </d:prop>
        </d:propfind>'''

        try:
            response, code, _ = self._make_request(
                url,
                method='PROPFIND',
                data=xml_request,
                headers={'Depth': '0', 'Content-Type': 'text/xml'},
                timeout=10
            )

            if code == 207:
                root = ET.fromstring(response)
                size_elem = root.find('.//{DAV:}getcontentlength')
                if size_elem is not None and size_elem.text:
                    return int(size_elem.text)
        except:
            pass

        return 0

    def upload_file_stream(self, local_path, remote_path, max_retries=MAX_RETRIES):
        """Alternative: Upload using a streaming approach with smaller writes"""
        if not remote_path.startswith('/'):
            remote_path = '/' + remote_path

        if remote_path.endswith('/') or not os.path.splitext(remote_path)[1]:
            remote_path = remote_path.rstrip('/') + '/' + os.path.basename(local_path)

        url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"
        file_size = os.path.getsize(local_path)
        filename = os.path.basename(local_path)

        print(f"Uploading {filename} ({file_size:,} bytes) using streaming method...")

        retries = 0
        uploaded = 0
        start_time = datetime.now()

        while retries <= max_retries:
            try:
                import http.client
                from urllib.parse import urlparse

                # Parse URL
                parsed = urlparse(url)

                # Create connection with shorter timeout
                conn = http.client.HTTPSConnection(
                    parsed.netloc,
                    timeout=30,  # 30 second timeout
                    context=ssl_context
                )

                # Prepare headers
                headers = {
                    'Content-Type': 'application/octet-stream',
                    'Content-Length': str(file_size - uploaded),
                    'Connection': 'close',  # Close connection after request
                }

                if self.username and self.password:
                    credentials = base64.b64encode(f"{self.username}:{self.password}".encode()).decode()
                    headers['Authorization'] = f'Basic {credentials}'

                # Start request
                conn.putrequest('PUT', parsed.path)
                for key, value in headers.items():
                    conn.putheader(key, value)
                conn.endheaders()

                # Stream file in small chunks
                with open(local_path, 'rb') as f:
                    if uploaded > 0:
                        f.seek(uploaded)

                    last_update = time.time()
                    chunk_size = 64 * 1024  # 64KB chunks

                    while True:
                        chunk = f.read(chunk_size)
                        if not chunk:
                            break

                        try:
                            conn.send(chunk)
                            uploaded += len(chunk)

                            # Update progress
                            current_time = time.time()
                            if current_time - last_update >= 0.5:
                                elapsed = (datetime.now() - start_time).total_seconds()
                                speed = uploaded / elapsed if elapsed > 0 else 0
                                progress_pct = (uploaded / file_size) * 100

                                # Calculate ETA
                                if speed > 0:
                                    eta_seconds = (file_size - uploaded) / speed
                                    eta = str(timedelta(seconds=int(eta_seconds)))
                                else:
                                    eta = "unknown"

                                # Format speed
                                if speed < 1024:
                                    speed_str = f"{speed:.1f} B/s"
                                elif speed < 1024 * 1024:
                                    speed_str = f"{speed / 1024:.1f} KB/s"
                                else:
                                    speed_str = f"{speed / (1024 * 1024):.1f} MB/s"

                                # Progress bar
                                bar_width = 20
                                filled_width = int(bar_width * progress_pct / 100)
                                bar = '█' * filled_width + '░' * (bar_width - filled_width)

                                sys.stdout.write(
                                    f"\r{filename} | {bar} | {progress_pct:.1f}% | {speed_str} | ETA: {eta}")
                                sys.stdout.flush()
                                last_update = current_time

                        except (BrokenPipeError, ConnectionResetError) as e:
                            raise e

                # Get response
                response = conn.getresponse()
                if response.status in [201, 204]:
                    sys.stdout.write(f"\r{filename} | {'█' * 20} | 100.0% | Complete" + " " * 30 + "\n")
                    sys.stdout.flush()
                    return True
                else:
                    raise Exception(f"Upload failed with status {response.status}")

            except (ConnectionResetError, BrokenPipeError, ConnectionAbortedError) as e:
                retries += 1
                if retries <= max_retries:
                    wait_time = min(RETRY_DELAY * retries, 30)
                    print(
                        f"\nConnection lost at {uploaded:,} bytes. Retrying in {wait_time}s... ({retries}/{max_retries})")
                    time.sleep(wait_time)
                else:
                    print(f"\nUpload failed after {max_retries} retries: {e}")
                    return False
            except Exception as e:
                print(f"\nUpload error: {e}")
                return False

        return False

    def create_directory(self, remote_path):
        """Create a directory"""
        if remote_path.startswith('/Global/') or remote_path == '/Global':
            url = f"{self.webdav_url}/{self.username}/{urllib.parse.quote(remote_path.lstrip('/'))}"
        else:
            url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"

        try:
            _, code, _ = self._make_request(url, method='MKCOL', timeout=10)
            return code in [201, 405]  # 405 means already exists
        except:
            return False

    def download_file(self, remote_path, local_path):
        """Download a file with resume support"""
        if remote_path.startswith('http'):
            print("Error: Public share links are switched off in this Nextcloud instance.")
            return False
        else:
            if remote_path.startswith('/Global/'):
                url = f"{self.webdav_url}/{self.username}/{urllib.parse.quote(remote_path.lstrip('/'))}"
            else:
                url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"

        try:
            # Check if partial download exists
            resume_pos = 0
            if os.path.exists(local_path + '.part'):
                resume_pos = os.path.getsize(local_path + '.part')
                print(f"Resuming download from {resume_pos:,} bytes...")

            req = urllib.request.Request(url)
            if self.username and self.password:
                credentials = base64.b64encode(f"{self.username}:{self.password}".encode()).decode()
                req.add_header('Authorization', f'Basic {credentials}')

            # Add range header for resume
            if resume_pos > 0:
                req.add_header('Range', f'bytes={resume_pos}-')

            with urllib.request.urlopen(req, context=ssl_context, timeout=60) as response:
                # Create directory if needed
                os.makedirs(os.path.dirname(local_path) or '.', exist_ok=True)

                # Get total size
                content_range = response.headers.get('Content-Range', '')
                if content_range:
                    total_size = int(content_range.split('/')[-1])
                else:
                    total_size = int(response.headers.get('Content-Length', 0)) + resume_pos

                # Download with progress
                downloaded = resume_pos
                mode = 'ab' if resume_pos > 0 else 'wb'

                with open(local_path + '.part', mode) as f:
                    while True:
                        chunk = response.read(8192)
                        if not chunk:
                            break
                        f.write(chunk)
                        downloaded += len(chunk)

                        if total_size > 0:
                            progress = int(50 * downloaded / total_size)
                            sys.stdout.write(
                                f"\r[{'=' * progress}{' ' * (50 - progress)}] {downloaded:,}/{total_size:,} bytes")
                            sys.stdout.flush()

                # Move completed download
                os.rename(local_path + '.part', local_path)

                if total_size > 0:
                    sys.stdout.write('\n')
                return True

        except Exception as e:
            print(f"\nDownload error: {e}")
            return False

    def list_files(self, remote_path):
        """List files in a directory"""
        if remote_path.startswith('/Global/') or remote_path == '/Global':
            url = f"{self.webdav_url}/{self.username}/{urllib.parse.quote(remote_path.lstrip('/'))}"
        else:
            url = f"{self.webdav_url}/{self.username}{urllib.parse.quote(remote_path)}"

        xml_request = '''<?xml version="1.0" encoding="UTF-8"?>
        <d:propfind xmlns:d="DAV:">
            <d:prop>
                <d:displayname/>
                <d:getcontentlength/>
                <d:resourcetype/>
                <d:getlastmodified/>
            </d:prop>
        </d:propfind>'''

        headers = {
            'Depth': '1',
            'Content-Type': 'text/xml'
        }

        try:
            response, code, _ = self._make_request(url, method='PROPFIND', data=xml_request, headers=headers,
                                                   timeout=10)

            if code == 207:
                root = ET.fromstring(response)
                files = []

                for response_elem in root.findall('.//{DAV:}response'):
                    href = response_elem.find('{DAV:}href').text
                    displayname_elem = response_elem.find('.//{DAV:}displayname')
                    resourcetype = response_elem.find('.//{DAV:}resourcetype')

                    if displayname_elem is not None and displayname_elem.text:
                        name = displayname_elem.text
                        is_dir = resourcetype.find('{DAV:}collection') is not None
                        files.append({
                            'name': name,
                            'path': href,
                            'type': 'directory' if is_dir else 'file'
                        })

                return files[1:]  # Skip the directory itself
        except:
            return []

    def share_internal(self, path, group_or_user, permissions='read'):
        """Create internal share with user"""
        print("Note: This Nextcloud instance is configured for internal sharing only.")
        print("Public share links are switched off and group sharing is not implemented.")
        print(f"Sharing {path} with {group_or_user}...")

        share_type = 0  # 0=user
        share_with = group_or_user.lstrip('@')

        perm_map = {
            'read': 1,
            'write': 15,
            'all': 31
        }

        params = {
            'path': path,
            'shareType': str(share_type),
            'shareWith': share_with,
            'permissions': str(perm_map.get(permissions, 1))
        }

        headers = {
            'OCS-APIRequest': 'true',
            'Content-Type': 'application/x-www-form-urlencoded'
        }

        data = urllib.parse.urlencode(params)
        url = f"{self.ocs_url}/shares?format=json"

        try:
            response, code, _ = self._make_request(url, method='POST', data=data, headers=headers, timeout=10)

            if code == 200:
                result = json.loads(response)
                if result['ocs']['meta']['status'] == 'ok':
                    return True
        except:
            pass
        return False


def get_credentials(args):
    """Get credentials from environment or prompt"""
    token = getattr(args, 'token', None) or os.environ.get('NEXTCLOUD_TOKEN')

    if token:
        if ':' in token:
            return token.split(':', 1)
        else:
            print("Error: Token must be in format 'username:your-app-password'")
            sys.exit(1)
    else:
        print(f"PCP-DKFZ Transfer Tool v{VERSION}")
        print(f"Server: {NEXTCLOUD_URL}\n")
        username = input("Username: ")
        password = getpass.getpass("Application Password: ")
        return username, password


def upload_recursive(client, local_path, remote_base, quiet=False, parallel=MAX_PARALLEL_UPLOADS, use_chunks=False):
    """Upload directory recursively with parallel uploads"""
    local_path = Path(local_path)
    uploaded = 0
    failed = 0

    upload_lock = threading.Lock()

    def upload_file_task(local_file, remote_file):
        nonlocal uploaded, failed
        success = client.upload_file(str(local_file), remote_file, max_retries=MAX_RETRIES, use_chunks=use_chunks)
        with upload_lock:
            if success:
                uploaded += 1
            else:
                failed += 1
        return success

    # Create remote directory
    remote_dir = f"{remote_base}/{local_path.name}"
    client.create_directory(remote_dir)

    # Collect all files and directories
    all_dirs = []
    all_files = []

    for root, dirs, files in os.walk(local_path):
        for dir_name in dirs:
            local_dir = Path(root) / dir_name
            rel_path = local_dir.relative_to(local_path.parent)
            remote_path = f"{remote_base}/{rel_path.as_posix()}"
            all_dirs.append(remote_path)

        for file_name in files:
            local_file = Path(root) / file_name
            rel_path = local_file.relative_to(local_path.parent)
            remote_file = f"{remote_base}/{rel_path.as_posix()}"
            all_files.append((local_file, remote_file))

    # Create all directories first
    for remote_path in all_dirs:
        client.create_directory(remote_path)

    # Upload files
    if parallel > 1 and len(all_files) > 1:
        if not quiet:
            print(f"Using {parallel} parallel uploads for {len(all_files)} files...")

        with ThreadPoolExecutor(max_workers=parallel) as executor:
            futures = {
                executor.submit(upload_file_task, local_file, remote_file): (local_file, remote_file)
                for local_file, remote_file in all_files
            }

            for future in as_completed(futures):
                try:
                    future.result()
                except Exception as e:
                    print(f"\nError uploading {futures[future][0]}: {e}")
    else:
        for local_file, remote_file in all_files:
            upload_file_task(local_file, remote_file)

    return uploaded, failed


def main():
    parser = argparse.ArgumentParser(
        description='PCP-DKFZ Transfer Tool - Upload, download, and share files internally',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Examples:
  # Upload file (uses fast streaming by default)
  %(prog)s upload myfile.pdf /Documents/

  # Upload with robust chunked mode (for bad connections)
  %(prog)s upload --chunk large_file.bin /Global/

  # Upload chunks in parallel for faster chunked uploads
  %(prog)s upload --chunk --parallel-chunks 4 huge_file.bin /Global/

  # Upload directory with 4 parallel file uploads
  %(prog)s upload -p 4 my_folder /Documents/

  # Download file  
  %(prog)s download /Documents/report.pdf ./

  # List files in Global shared folder
  %(prog)s list /Global/

  # Share with specific user
  %(prog)s share /Documents/report.pdf colleague_username

Environment:
  NEXTCLOUD_TOKEN=username:your-app-password

Shared Folders:
  /Global/      - All users (read/write)

Upload Methods:
  - Default: Fast streaming upload (entire file at once)
  - --chunk: Robust chunked upload (2MB chunks, slower but handles disconnects)
  - --parallel-chunks N: Upload N chunks simultaneously (only with --chunk)
  - -p N: Upload N files in parallel (for directories)

Note: If uploads fail due to connection resets, use --chunk mode or ask your
admin to increase proxy timeout settings.
        """
    )

    parser.add_argument('--version', action='version', version=f'%(prog)s {VERSION}')
    parser.add_argument('-t', '--token', help='Authentication token')
    parser.add_argument('-q', '--quiet', action='store_true', help='Quiet mode')
    parser.add_argument('-v', '--verbose', action='store_true', help='Verbose mode')

    subparsers = parser.add_subparsers(dest='command', help='Commands')

    # Upload command
    upload_parser = subparsers.add_parser('upload', help='Upload files or folders')
    upload_parser.add_argument('source', help='Local file or folder')
    upload_parser.add_argument('destination', help='Remote destination path')
    upload_parser.add_argument('-p', '--parallel', type=int, default=MAX_PARALLEL_UPLOADS,
                               help=f'Number of parallel uploads for multiple files (default: {MAX_PARALLEL_UPLOADS})')
    upload_parser.add_argument('--chunk', action='store_true',
                               help='Use chunked upload method (slower but more robust for bad connections)')
    upload_parser.add_argument('--parallel-chunks', type=int, default=1,
                               help='Number of parallel chunk uploads when using --chunk (default: 1)')
    upload_parser.add_argument('--stream', action='store_true',
                               help='Force streaming method (deprecated, this is now the default)')

    # Download command
    download_parser = subparsers.add_parser('download', help='Download files')
    download_parser.add_argument('source', help='Remote file path')
    download_parser.add_argument('destination', nargs='?', default='.', help='Local destination')

    # List command
    list_parser = subparsers.add_parser('list', help='List files in directory')
    list_parser.add_argument('path', nargs='?', default='/', help='Remote directory path')

    # Share command
    share_parser = subparsers.add_parser('share', help='Share internally with specific users')
    share_parser.add_argument('path', help='File or folder to share')
    share_parser.add_argument('target', help='Username to share with')
    share_parser.add_argument('-p', '--permissions', choices=['read', 'write', 'all'],
                              default='read', help='Share permissions')

    # Info command
    info_parser = subparsers.add_parser('info', help='Show information about shared folders')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    # Handle info command
    if args.command == 'info':
        print(f"\nPCP-DKFZ Transfer Tool v{VERSION}")
        print(f"Server: {NEXTCLOUD_URL}")
        print("\nShared Folders:")
        print("-" * 70)
        for folder, info in SHARED_FOLDERS.items():
            print(f"\n{folder}:")
            print(f"  Path: {info['path']}")
            print(f"  Description: {info['description']}")
            print(f"  Access: {info['access']}")
        print("\n" + "-" * 70)
        print("\nUPLOAD METHODS:")
        print("- Default (streaming): Fast, uploads entire file at once")
        print("- Chunked (--chunk): Slower but robust, uploads in 2MB pieces")
        print("- Parallel chunks (--chunk --parallel-chunks N): Faster chunked uploads")
        print("\nPARALLEL OPTIONS:")
        print("- -p N: Upload N different files simultaneously (for directories)")
        print("- --parallel-chunks N: Upload N chunks of same file simultaneously")
        print("\nTROUBLESHOOTING CONNECTION ISSUES:")
        print("- If uploads fail after ~3-4MB, use --chunk mode")
        print("- For faster chunked uploads: --chunk --parallel-chunks 4")
        print("- Contact your admin to increase proxy timeout settings")
        print("- Recommended nginx/traefik timeout: 3600s (1 hour)")
        return

    # Get credentials
    username, password = get_credentials(args)
    client = NextcloudClient(username, password, verbose=args.verbose)

    # Test connection
    if args.verbose:
        print("Testing connection... ", end='', flush=True)

    if not client.test_connection():
        print("Authentication failed! Check your credentials.")
        print(f"Get an app password from: {NEXTCLOUD_URL}/settings/user/security")
        sys.exit(1)
    elif args.verbose:
        print("✓")

    # Execute command
    if args.command == 'upload':
        source = Path(args.source)

        if not source.exists():
            print(f"Error: Source not found: {args.source}")
            sys.exit(1)

        if args.destination.startswith('/Global'):
            print(f"Uploading to Global shared folder")
            print(f"Access: {SHARED_FOLDERS['global']['access']}")

        if source.is_file():
            # Choose upload method
            if args.chunk:
                print("Using chunked upload method (robust mode)...")

            if client.upload_file(str(source), args.destination,
                                  use_chunks=args.chunk,
                                  parallel_chunks=getattr(args, 'parallel_chunks', 1)):
                if not args.quiet:
                    print(f"Uploaded to: {args.destination}")
            else:
                print("\nUpload failed. If you're experiencing connection issues, try:")
                print("1. Use chunked mode: pcpdt upload --chunk yourfile.bin /Global/")
                print("2. For faster chunked uploads: pcpdt upload --chunk --parallel-chunks 4 yourfile.bin /Global/")
                print("3. Ask your admin to check proxy timeout settings")
                sys.exit(1)

        elif source.is_dir():
            print(f"Uploading directory {source.name}...")
            if args.chunk:
                print("Using chunked upload method for all files...")
            uploaded, failed = upload_recursive(client, str(source), args.destination,
                                                args.quiet, args.parallel, args.chunk)
            print(f"\n✓ Uploaded {uploaded} files")
            if failed > 0:
                print(f"✗ Failed: {failed} files")
                sys.exit(1)

    elif args.command == 'download':
        local_dest = args.destination
        if os.path.isdir(local_dest):
            local_dest = os.path.join(local_dest, os.path.basename(args.source))

        print(f"Downloading {args.source}...")
        if client.download_file(args.source, local_dest):
            print(f"✓ Downloaded to {local_dest}")
        else:
            print("✗ Download failed")
            sys.exit(1)

    elif args.command == 'list':
        print(f"Listing {args.path}:")
        files = client.list_files(args.path)

        if files:
            print("-" * 50)
            for file in files:
                icon = "📁" if file['type'] == 'directory' else "📄"
                print(f"{icon} {file['name']}")
            print("-" * 50)
            print(f"Total: {len(files)} items")
        else:
            print("Directory is empty or not accessible")

    elif args.command == 'share':
        if client.share_internal(args.path, args.target, args.permissions):
            print(f"✓ Shared {args.path} with {args.target} ({args.permissions} access)")
        else:
            print("✗ Failed to create share")
            sys.exit(1)


if __name__ == "__main__":
    main()
